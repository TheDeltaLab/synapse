# Provider Keys (Tier 1 - Gateway → LLM Providers)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
# ALIBABA_API_KEY=sk-...             # Alibaba DashScope (text-embedding-v4)

# External Infrastructure
DATABASE_URL=postgresql://user:password@external-host:5432/synapse
REDIS_URL=redis://external-host:6379
# REDIS_AUTH=NONE              # NONE (default) | PASSWORD | AZURE_ENTRA_ID
# REDIS_USER=                  # Redis username (PASSWORD mode)
# REDIS_PASSWORD=              # Redis password (PASSWORD mode)

# Cache Configuration
# CACHE_ENABLED=true          # Set to 'false' to disable LLM response caching even with Redis connected
# CACHE_TTL=3600              # Cache time-to-live in seconds (default: 3600 = 1 hour)

# Async Log Buffer (RequestLog/EmbeddingLog writes)
# LOG_DB_POOL_SIZE=5                              # Dedicated PG pool size for log writes
# LOG_BUFFER_FLUSH_MS=1000                        # Periodic flush interval (ms)
# LOG_BUFFER_FLUSH_SIZE=100                       # Flush immediately when queue reaches this size
# LOG_BUFFER_MAX_SIZE=10000                       # Per-queue cap; oldest dropped when exceeded
# LOG_BUFFER_DEAD_LETTER_FILE=.synapse-log-dead-letter.jsonl  # Failed-row sink after retries

# Gateway Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Web App Configuration
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
GATEWAY_URL=http://localhost:3000

# Encryption Key (32 bytes, base64 encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

JWT_SECRET=

# for mock
# OPENAI_BASE_URL=http://localhost:9001
# ANTHROPIC_BASE_URL=http://localhost:9002
# GOOGLE_BASE_URL=http://localhost:9003
# OPENROUTER_BASE_URL=http://localhost:9004
# DEEPSEEK_BASE_URL=http://localhost:9001
# ALIBABA_BASE_URL=http://localhost:9001


OTEL_SERVICE_NAME=synapse-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3034