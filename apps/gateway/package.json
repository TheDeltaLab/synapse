    "@prisma/client": "^7.4.2",
    "@synapse/dal": "workspace:*",
    "@synapse/shared": "workspace:*",
    "ai": "^6.0.111",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "hono": "catalog:",
    "redis": "^5.6.0",
    "pg": "^8.20.0"
