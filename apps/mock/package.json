{
  "name": "@synapse/mock",
  "version": "0.1.0",
  "description": "Mock LLM provider servers for local development and testing",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@hono/node-server": "catalog:",
    "dotenv": "^17.3.1",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@synapse/eslint-config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "catalog:",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
