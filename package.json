{
  "name": "@synapse/root",
  "version": "0.1.0",
  "private": true,
  "description": "AI Gateway Monorepo - Unified LLM provider access with caching and retry logic",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "set -a; [ -f .env ] && . ./.env; set +a; pnpm --parallel --filter gateway --filter @synapse/dashboard dev",
    "dev-mock": "set -a; [ -f .env ] && . ./.env; set +a; pnpm --filter @synapse/mock... dev & sleep 2 && pnpm --parallel --filter gateway --filter @synapse/dashboard dev",
    "build": "pnpm --recursive --filter \"./packages/*\" --if-present build && pnpm --filter \"./apps/*\" build",
    "test": "pnpm --recursive --filter \"./packages/*\" --if-present build && pnpm --recursive --if-present test",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive --filter \"./packages/*\" --if-present build && pnpm --recursive type-check",
    "clean": "pnpm --recursive --if-present clean && rm -rf node_modules"
  },
  "keywords": ["ai", "gateway", "llm", "openai", "anthropic", "hono", "monorepo"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "@prisma/engines", "esbuild", "prisma"]
  }
}
