{
  "name": "@synapse/dal",
  "version": "0.1.0",
  "description": "Data Access Layer with Prisma ORM for Synapse",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./prisma/client": {
      "types": "./generated/prisma/client.ts",
      "default": "./generated/prisma/client.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed.ts"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.12",
    "prisma": "^7.4.1",
    "tsx": "^4.19.2"
  }
}
