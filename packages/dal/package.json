{
  "name": "@synapse/dal",
  "version": "0.1.0",
  "description": "Data Access Layer with Prisma ORM for Synapse",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./prisma/client": {
      "types": "./generated/prisma/client.ts",
      "default": "./generated/prisma/client.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed.ts"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@synapse/config": "workspace:*",
    "@types/node": "^22.19.12",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2"
  }
}
