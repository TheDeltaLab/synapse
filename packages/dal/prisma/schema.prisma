// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApiKey {
  id          String    @id @default(uuid())
  key         String    @unique // bcrypt hash
  name        String
  userId      String?   // Optional: for multi-tenant support
  rateLimit   Int       @default(1000) // requests per hour
  enabled     Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  requestLogs   RequestLog[]
  embeddingLogs EmbeddingLog[]

  @@index([key])
  @@map("api_keys")
}

model RequestLog {
  id              String    @id @default(uuid())
  apiKeyId        String
  apiKey          ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  provider        String    // openai, anthropic, google, etc.
  model           String    // gpt-4o, claude-3-5-sonnet, etc.

  // Enhanced token tracking
  inputTokens     Int?
  outputTokens    Int?
  totalTokens     Int?      // Renamed from 'tokens'

  // Encrypted content (AES-256-GCM)
  promptContent   Bytes?    // Encrypted JSON of messages
  responseContent Bytes?    // Encrypted response text
  contentIv       Bytes?    // Initialization vector
  contentTag      Bytes?    // Auth tag

  // Enhanced cache tracking
  cached          Boolean   @default(false)
  cacheType       String?   // 'semantic', 'exact', 'none'
  cacheTtl        Int?
  costSaving      Float?
  latencySaving   Int?

  latency         Int?      // Milliseconds
  statusCode      Int       // HTTP status code
  createdAt       DateTime  @default(now())

  @@index([apiKeyId, createdAt])
  @@index([provider, model])
  @@index([createdAt])
  @@index([cached])
  @@map("request_logs")
}

model EmbeddingLog {
  id          String   @id @default(uuid())
  apiKeyId    String
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  // Request metadata
  provider    String   // openai, google, openrouter
  model       String   // text-embedding-3-small, text-embedding-004, etc.

  // Request details
  inputCount  Int      // Number of input texts (> 1 for batch requests)
  dimensions  Int?     // Requested dimensions (if specified)

  // Usage stats
  tokens      Int?     // Token consumption

  // Performance metrics
  latency     Int?     // Latency in milliseconds
  statusCode  Int      // HTTP status code

  // Timestamps
  createdAt   DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([provider, model])
  @@index([createdAt])
  @@map("embedding_logs")
}

enum UserRole {
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_PASSWORD_RESET
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  name        String
  role        UserRole    @default(STAFF)
  status      UserStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastLoginAt DateTime?

  authProviders AuthProvider[]

  @@map("users")
}

model AuthProvider {
  id              String   @id @default(uuid())
  userId          String
  name            String   // Provider name: "password", "google", "github", etc.
  providerId      String   // For password: bcrypt hash; For OAuth: external user ID
  providerOptions Json?    // { salt: "base64..." } for password provider
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, providerId, userId])
  @@index([userId])
  @@map("auth_providers")
}
