# Extract Mimir binary from official image
FROM --platform=linux/amd64 grafana/mimir:2.15.0 AS mimir

# Use Alpine as base for shell access (debugging, env var expansion)
FROM --platform=linux/amd64 alpine:3.21
RUN apk add --no-cache bash ca-certificates
COPY --from=mimir /bin/mimir /usr/bin/mimir
COPY mimir-config.yaml /etc/mimir/config.yaml
ENTRYPOINT ["/usr/bin/mimir"]
CMD ["-config.file=/etc/mimir/config.yaml", "-config.expand-env=true"]
