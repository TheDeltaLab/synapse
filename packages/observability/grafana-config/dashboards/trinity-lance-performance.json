{
  "uid": "trinity-lance-performance",
  "_folderUid": "trinity",
  "title": "Trinity Lance: Query Performance",
  "tags": ["trinity", "lance", "performance"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Query Execution (Prometheus Metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Query Execution Duration Percentiles (toArray)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lance_query_execution_duration_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lance_query_execution_duration_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lance_query_execution_duration_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "type": "row",
      "title": "Execution Breakdown (Loki Logs)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Avg Stage Durations (Last 5m)",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "avg(avg_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap preparedMs [5m]))",
          "legendFormat": "Prepare",
          "refId": "prepared"
        },
        {
          "expr": "avg(avg_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap appliedMs [5m]))",
          "legendFormat": "Apply Ops",
          "refId": "applied"
        },
        {
          "expr": "avg(avg_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap queriedMs [5m]))",
          "legendFormat": "Query (toArray)",
          "refId": "queried"
        },
        {
          "expr": "avg(avg_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap serializedMs [5m]))",
          "legendFormat": "Serialize",
          "refId": "serialized"
        },
        {
          "expr": "avg(avg_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap convertedTimestampMs [5m]))",
          "legendFormat": "Convert Timestamps",
          "refId": "converted"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Total Execution Time (Max)",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "max(max_over_time({service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | unwrap totalMs [5m]))",
          "legendFormat": "Max Total Time",
          "refId": "total"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent Slow Execution Logs",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true
      },
      "targets": [
        {
          "expr": "{service_name=~\"lance|lance-worker\"} |= `trinity_lance_query_execute_performance` | regexp `^(.*)\\s+(?P<json_data>\\{.*\\})$` | line_format \"{{.json_data}}\" | json | totalMs > 1000",
          "refId": "logs"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
