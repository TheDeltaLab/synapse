{
  "uid": "trinity-lance",
  "_folderUid": "trinity",
  "title": "Trinity Lance",
  "tags": ["trinity", "lance", "otel"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Queries (5m)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(increase(lance_query_count_total[5m]))",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Record Ops (5m)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(increase(lance_record_op_count_total[5m]))",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Query P99 Latency",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 3000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by (le) (rate(lance_query_duration_bucket[5m])))",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Sync Failures (5m)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(increase(lance_sync_event_count_total{status=\"failed\"}[5m])) or vector(0)",
        "legendFormat": "",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "Queries",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Query Rate by Table",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "sum by (table) (rate(lance_query_count_total[5m]))",
        "legendFormat": "{{ table }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Query Rate by Type",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "sum by (type) (rate(lance_query_count_total[5m]))",
        "legendFormat": "{{ type }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Query Duration Percentiles",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lance_query_duration_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lance_query_duration_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lance_query_duration_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "type": "row",
      "title": "Record Operations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Record Op Rate by Table & Op",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "sum by (table, op) (rate(lance_record_op_count_total[5m]))",
        "legendFormat": "{{ table }} / {{ op }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Record Op Failures",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "sum by (table, op) (rate(lance_record_op_count_total{status=\"failed\"}[5m]))",
        "legendFormat": "{{ table }} / {{ op }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Record Op Duration Percentiles",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lance_record_op_duration_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lance_record_op_duration_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lance_record_op_duration_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "type": "row",
      "title": "CDC Sync",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Sync Event Rate by Table",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "sum by (table, status) (rate(lance_sync_event_count_total[5m]))",
        "legendFormat": "{{ table }} ({{ status }})",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Sync Latency Percentiles",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lance_sync_latency_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lance_sync_latency_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lance_sync_latency_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Table Optimization Duration",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, table) (rate(lance_optimize_duration_bucket[5m])))",
        "legendFormat": "{{ table }} p95",
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 39
}
