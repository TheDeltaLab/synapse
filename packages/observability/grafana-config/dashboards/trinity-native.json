{
  "uid": "trinity-native",
  "_folderUid": "trinity",
  "title": "Trinity Native App",
  "tags": ["trinity", "native", "otel"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total HTTP Requests",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(http_client_request_count{job=\"native\"})",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(app_error_count{job=\"native\"}) or vector(0)",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Total BLE Ops",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(ble_operation_count{job=\"native\"}) or vector(0)",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Avg Startup Time",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 8000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(app_startup_duration_sum{job=\"native\"}) / clamp_min(sum(app_startup_duration_count{job=\"native\"}), 1)",
        "legendFormat": "",
        "refId": "A"
      }]
    },
    {
      "type": "row",
      "title": "HTTP Client (RED Metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto"
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_client_request_count{job=\"native\"}[$__rate_interval]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum by (http_route) (rate(http_client_request_count{job=\"native\"}[$__rate_interval]))",
          "legendFormat": "{{ http_route }}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate %",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "100 * sum(rate(http_client_request_count{job=\"native\", http_status_code=~\"[45].*\"}[$__rate_interval])) / clamp_min(sum(rate(http_client_request_count{job=\"native\"}[$__rate_interval])), 1)",
        "legendFormat": "Error %",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_request_duration_bucket{job=\"native\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_bucket{job=\"native\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_client_request_duration_bucket{job=\"native\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "table",
      "title": "Request Breakdown by Route",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 0 }]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Latency" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "decimals", "value": 0 }]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "http_route": "Route",
              "http_method": "Method",
              "Value #A": "Total",
              "Value #B": "Avg Latency"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total", "desc": true }]
      },
      "targets": [
        {
          "expr": "sum by (http_method, http_route) (http_client_request_count{job=\"native\"})",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (http_method, http_route) (http_client_request_duration_sum{job=\"native\"}) / clamp_min(sum by (http_method, http_route) (http_client_request_duration_count{job=\"native\"}), 1)",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "BLE Operations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "BLE Operations by Type",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [{
        "expr": "sum by (operation) (rate(ble_operation_count{job=\"native\"}[$__rate_interval]))",
        "legendFormat": "{{ operation }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "BLE Failure Rate by Operation",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "100 * sum by (operation) (rate(ble_operation_count{job=\"native\", success=\"false\"}[$__rate_interval])) / clamp_min(sum by (operation) (rate(ble_operation_count{job=\"native\"}[$__rate_interval])), 1)",
        "legendFormat": "{{ operation }}",
        "refId": "A"
      }]
    },
    {
      "type": "row",
      "title": "App Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Errors by Type",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [{
        "expr": "sum by (error_type) (rate(app_error_count{job=\"native\"}[$__rate_interval]))",
        "legendFormat": "{{ error_type }}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "App Startup Duration",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(app_startup_duration_bucket{job=\"native\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(app_startup_duration_bucket{job=\"native\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 2
}
