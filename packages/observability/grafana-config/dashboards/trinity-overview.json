{
  "uid": "trinity-overview",
  "_folderUid": "trinity",
  "title": "Trinity Overview",
  "tags": ["trinity", "overview", "otel"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Native App",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "HTTP Requests",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-native?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(http_client_request_count{job=\"native\"})",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Errors",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-native?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(app_error_count{job=\"native\"}) or vector(0)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "BLE Ops",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-native?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(ble_operation_count{job=\"native\"}) or vector(0)",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Native Error Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0"
        }
      },
      "targets": [{
        "expr": "sum(rate(app_error_count{job=\"native\"}[$__rate_interval]))",
        "legendFormat": "errors/s",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Native Request Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0"
        }
      },
      "targets": [{
        "expr": "sum(rate(http_client_request_count{job=\"native\"}[$__rate_interval]))",
        "legendFormat": "req/s",
        "refId": "A"
      }]
    },
    {
      "type": "row",
      "title": "Web App",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "HTTP Requests",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-web?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(http_client_request_duration_count{job=\"web\"}) or vector(0)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-web?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "100 * sum(rate(http_client_request_duration_count{job=\"web\", http_response_status_code=~\"[45].*\"}[5m])) / clamp_min(sum(rate(http_client_request_duration_count{job=\"web\"}[5m])), 0.001) or vector(0)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Heap Used",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          },
          "links": [{ "title": "Detail", "url": "/d/trinity-web?orgId=1" }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "v8js_memory_heap_used{job=\"web\"} or vector(0)",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Web Request Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0"
        }
      },
      "targets": [{
        "expr": "sum(rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval]))",
        "legendFormat": "req/s",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Web Latency p95",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0"
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_bucket{job=\"web\"}[$__rate_interval])))",
        "legendFormat": "p95",
        "refId": "A"
      }]
    },
    {
      "type": "row",
      "title": "Alerting",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "type": "alertlist",
      "title": "Active Alerts",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 11 },
      "options": {
        "showOptions": "current",
        "maxItems": 10,
        "sortOrder": 1,
        "alertName": "",
        "dashboardAlerts": false,
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "normal": false,
          "error": false
        },
        "folder": { "title": "Trinity" }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
