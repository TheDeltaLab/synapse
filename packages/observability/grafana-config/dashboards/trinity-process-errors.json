{
  "uid": "trinity-process-errors",
  "_folderUid": "trinity",
  "title": "Trinity Process Errors",
  "tags": ["trinity", "errors", "loki"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Uncaught Exceptions",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "uncaughtException Count",
      "description": "Process-level uncaught exceptions. Each occurrence means the process state may be corrupted — a restart should follow.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (job) (count_over_time({job=~\"web|admin|home|worker|lance|lance-worker\"} |= `[uncaughtException]` [$__interval]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "unhandledRejection Count",
      "description": "Unhandled promise rejections. Usually indicates missing .catch() or await. Process continues but async operations may silently fail.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (job) (count_over_time({job=~\"web|admin|home|worker|lance|lance-worker\"} |= `[unhandledRejection]` [$__interval]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Next.js Route Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "onRequestError Count (by service)",
      "description": "Unhandled exceptions inside Next.js route handlers. Users see 500 errors.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (job) (count_over_time({job=~\"web|admin|home\"} |= `[onRequestError]` [$__interval]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "onRequestError Top Paths",
      "description": "Which routes are throwing the most unhandled errors.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (http_path) (count_over_time({job=~\"web|admin|home\"} |= `[onRequestError]` | json | __error__=`` [$__range]))",
          "legendFormat": "{{ http_path }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Framework Errors (Koa / Hono)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Koa / Hono Error Count",
      "description": "Errors caught by Koa app.on('error') or Hono app.onError. These are middleware-level errors that returned 500 to the client.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (job) (count_over_time({job=~\"worker|lance|lance-worker\"} |~ `\\[(Koa|Hono) Error\\]` [$__interval]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Error Log Details",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "All Error Logs (latest)",
      "description": "Raw log entries for all captured errors. Click a row to see full stack trace and attributes.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "{job=~\"web|admin|home|worker|lance|lance-worker\"} |~ `\\[(uncaughtException|unhandledRejection|onRequestError|Koa Error|Hono Error)\\]`",
          "refId": "A"
        }
      ]
    }
  ]
}
