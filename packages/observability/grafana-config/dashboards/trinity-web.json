{
  "uid": "trinity-web",
  "_folderUid": "trinity",
  "title": "Trinity Web App",
  "tags": ["trinity", "web", "otel"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "HTTP Client (Outbound Requests)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum by (server_address) (rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval]))",
          "legendFormat": "{{ server_address }}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate %",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_client_request_duration_count{job=\"web\", http_response_status_code=~\"5.*\"}[$__rate_interval])) / clamp_min(sum(rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval])), 1)",
          "legendFormat": "5xx %",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(http_client_request_duration_count{job=\"web\", http_response_status_code=~\"4.*\"}[$__rate_interval])) / clamp_min(sum(rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval])), 1)",
          "legendFormat": "4xx %",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_request_duration_bucket{job=\"web\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_bucket{job=\"web\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_client_request_duration_bucket{job=\"web\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "table",
      "title": "Request Breakdown by Server",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rate" },
            "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "p95 Latency" },
            "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }]
          },
          {
            "matcher": { "id": "byName", "options": "Error %" },
            "properties": [{ "id": "unit", "value": "percent" }, { "id": "decimals", "value": 1 }]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "server_address": "Server",
              "http_request_method": "Method",
              "Value #A": "Rate",
              "Value #B": "p95 Latency",
              "Value #C": "Error %"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Rate", "desc": true }]
      },
      "targets": [
        {
          "expr": "sum by (http_request_method, server_address) (rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (http_request_method, server_address, le) (rate(http_client_request_duration_bucket{job=\"web\"}[$__rate_interval])))",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "100 * sum by (http_request_method, server_address) (rate(http_client_request_duration_count{job=\"web\", http_response_status_code=~\"[45].*\"}[$__rate_interval])) / clamp_min(sum by (http_request_method, server_address) (rate(http_client_request_duration_count{job=\"web\"}[$__rate_interval])), 1)",
          "legendFormat": "",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Node.js Runtime",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Heap Memory Usage",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "v8js_memory_heap_used{job=\"web\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "v8js_memory_heap_limit{job=\"web\"}",
          "legendFormat": "Limit",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Loop Delay",
      "datasource": { "uid": "mimir", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_delay_p50{job=\"web\"}",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_delay_p90{job=\"web\"}",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "nodejs_eventloop_delay_p99{job=\"web\"}",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
