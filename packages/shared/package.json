{
  "name": "@synapse/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for Synapse",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@synapse/config": "workspace:*",
    "@synapse/eslint-config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "tsup": "^8.4.0"
  }
}
